# infosec-job-market-intel — local configuration template
#
# Copy this file to `.env` and fill in the values for your environment.
# `.env` is gitignored and will never be committed.
#
#   cp .env.example .env
#
# All variables are OPTIONAL. The tool degrades gracefully:
#   - No USAJobs ref      -> the USAJobs collector is skipped (warning printed).
#   - No Anthropic ref    -> LLM enrichment is skipped (regex extraction only).
#   - No JOBMARKET_OP_PATH -> assumes `op` is on your PATH.
#
# A run with `--sites greenhouse lever` needs none of these set.

# ---------------------------------------------------------------------------
# 1Password CLI
# ---------------------------------------------------------------------------
# Path to the `op` binary. Leave blank to use whatever `op` is on PATH.
# Example (Windows + WinGet):
#   JOBMARKET_OP_PATH=C:\Users\YOU\AppData\Local\Microsoft\WinGet\Packages\AgileBits.1Password.CLI_...\op.exe
JOBMARKET_OP_PATH=

# ---------------------------------------------------------------------------
# USAJobs.gov API
# ---------------------------------------------------------------------------
# Free signup at https://developer.usajobs.gov/. Create a 1Password item
# whose "notesPlain" field contains JSON:
#   {"email": "you@example.com", "api_key": "..."}
# Then point this var at that item via an op:// reference.
#
# Example:
#   JOBMARKET_USAJOBS_SECRET_REF=op://YOUR_VAULT_ID/usajobs-api/notesPlain
JOBMARKET_USAJOBS_SECRET_REF=

# ---------------------------------------------------------------------------
# Anthropic API (Claude enrichment)
# ---------------------------------------------------------------------------
# Generate a key at https://console.anthropic.com/. Store the raw key string
# in a 1Password item's "notesPlain" field, then reference it here.
#
# Example:
#   JOBMARKET_ANTHROPIC_SECRET_REF=op://YOUR_VAULT_ID/anthropic-api-key/notesPlain
JOBMARKET_ANTHROPIC_SECRET_REF=

# ---------------------------------------------------------------------------
# Keyring service name
# ---------------------------------------------------------------------------
# The OS-level keyring service name used to cache decrypted credentials so we
# don't hit 1Password on every run. Override only if you run multiple copies
# of the tool and want them to keep separate caches.
JOBMARKET_KEYRING_SERVICE=JobMarketIntel
